# .env — copy this to .env and fill in real values
# Never commit .env to git

# When running Python directly (local dev): use 127.0.0.1
# When running inside Docker: docker-compose.yml overrides this to 'db' automatically
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=court_scraper
DB_USER=scraper_user
DB_PASSWORD=CHANGE_ME

SCRAPER_LOG_LEVEL=INFO
